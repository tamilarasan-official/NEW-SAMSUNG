# ============================================
# GIT IGNORE FILE
# ============================================

# Environment variables
.env
.env.local
.env.*.local

# Dependencies (should NEVER be in main folder)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Only allow package-lock in bbnl-proxy
!bbnl-proxy/package-lock.json

# Build outputs
dist/
build/
*.wgt
.buildResult/
.sign/

# IDE
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
.cache/

# Tizen Studio
.tproject
.project
.cproject
.settings/

# Backup files
*.bak
*~
*.orig
