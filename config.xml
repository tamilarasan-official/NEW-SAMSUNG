<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://yourdomain/BasicProject2"
        version="1.0.0"
        viewmodes="maximized">

    <!-- Samsung TV profile -->
    <tizen:profile name="tv-samsung"/>

    <!-- Application identity -->
    <tizen:application
        id="ph3Ha7N8EQ.BasicProject2"
        package="ph3Ha7N8EQ"
        required_version="6.0"/>

    <content src="login.html"/>
    <name>BasicProject2</name>
    <icon src="icon.png"/>

    <!-- REQUIRED for API + IPTV -->
    <access origin="*" subdomains="true"/>
    <access origin="http://124.40.244.211" subdomains="true"/>

    <!-- Network -->
    <tizen:privilege name="http://tizen.org/privilege/internet"/>
    <tizen:privilege name="http://tizen.org/privilege/network.get"/>
    <tizen:privilege name="http://tizen.org/privilege/network.post"/>
    <tizen:privilege name="http://tizen.org/privilege/download"/>

    <!-- TV Remote -->
    <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice"/>

    <!-- AVPlay (future IPTV use) -->
    <tizen:privilege name="http://developer.samsung.com/privilege/avplay"/>
    <tizen:privilege name="http://developer.samsung.com/privilege/productinfo"/>
    <tizen:privilege name="http://developer.samsung.com/privilege/network.public"/>

    <tizen:setting
        screen-orientation="landscape"
        background-support="disable"
        hwkey-event="enable"/>

</widget>
